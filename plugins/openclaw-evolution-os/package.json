  "version": "0.1.0-draft",
  "description": "OpenClaw host integration adapter for agent-evolution-os.",
  "type": "module",
  "private": true,
  "main": "src/index.js",
  "openclaw": {
    "extensions": ["./src/index.js"],
    "compat": {
      "pluginApi": ">=2026.5.27",
